/* 全局样式 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.page { 
  padding: 16rpx; 
  box-sizing: border-box; 
}

.card { 
  background:#fff; 
  border-radius:16rpx; 
  padding:24rpx; 
  box-shadow:0 8rpx 24rpx rgba(0,0,0,.04); 
  margin-bottom:24rpx; 
}

.title { 
  font-size:34rpx; 
  font-weight:600; 
  margin-bottom:16rpx; 
}

.btn { 
  background:#1677ff; 
  color:#fff; 
  border-radius:12rpx; 
  padding:20rpx 28rpx; 
  border: none;
}

.btn[disabled]{ 
  opacity:.5; 
}

.input { 
  background:#f6f7fb; 
  border-radius:12rpx; 
  padding:16rpx; 
  margin-bottom:16rpx; 
}

.small { 
  color:#999; 
  font-size:24rpx; 
}

.row { 
  display:flex; 
  gap:16rpx; 
}

.col { 
  flex:1; 
}

/* 通用按钮样式 */
button {
  border: none;
  border-radius: 12rpx;
}

button::after {
  border: none;
}

/* 通用输入框样式 */
input, textarea {
  text-align: left !important;
  box-sizing: border-box;
  text-align-last: left;
}

input::placeholder, textarea::placeholder {
  text-align: left !important;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-left: 20rpx;
}
