/* pages/create/index.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  height: 100%;
  width: 100%;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.agent-grid {
  width: 100%;
  margin-bottom: 40rpx;
  overflow: hidden;
  /* 使用 flexbox 布局，更可靠 */
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.agent-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  width: 48%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  /* 移除 float，使用 flexbox */
}

/* 移除第5个的特殊居中样式，让所有项目正常排列（2列布局） */
/* 如果有6个项目，会自动排列成3行2列 */

.agent-item:active {
  opacity: 0.8;
}

.agent-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.character-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.world-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.dialog-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.image-icon {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.story-icon {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.video-icon {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.agent-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  text-align: center;
}

.agent-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.tips {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 40rpx;
  clear: both;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

/* 流程区域 */
.flow-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.flow-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.flow-more {
  font-size: 26rpx;
  color: #4facfe;
}

.flow-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e6f0ff 100%);
  border-radius: 20rpx;
  border: 2rpx solid #d6e4ff;
}

.flow-card:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.flow-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.flow-content {
  flex: 1;
}

.flow-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.flow-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.flow-arrow {
  font-size: 40rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 作品列表 */
.work-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.work-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 4rpx solid #4facfe;
}

.work-item:active {
  background: #f0f0f0;
}

.work-main {
  flex: 1;
}

.work-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.work-meta {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.work-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #fff;
  border-radius: 8rpx;
}

.work-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 16rpx;
}
