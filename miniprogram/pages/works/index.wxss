/* pages/works/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.merge-btn {
  margin-top: 12rpx;
  width: 220rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #3b4b7e;
  background: #fff;
  border: 1rpx solid #c8d1eb;
  border-radius: 12rpx;
}

.filter-tabs {
  display: flex;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
  flex-wrap: wrap;
}

.filter-tabs .tab-item {
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 20rpx;
  background: #f0f0f0;
}

.tab-item.active {
  background: #1677ff;
  color: #fff;
}

.works-list {
  display: flex;
  flex-direction: column;
}

.works-list .work-item {
  margin-bottom: 20rpx;
}

.works-list .work-item:last-child {
  margin-bottom: 0;
}

.work-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.work-content {
  flex: 1;
  display: flex;
  align-items: center;
}

.work-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.work-content .work-icon {
  margin-right: 24rpx;
}

.icon-text {
  font-size: 48rpx;
}

.work-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.work-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.work-time {
  font-size: 24rpx;
  color: #999;
}

.work-type {
  font-size: 24rpx;
  color: #1677ff;
  background: #f0f4ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
}

.work-stats {
  font-size: 24rpx;
  color: #666;
}

.work-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  transition: background 0.3s;
}

.action-icon-wrapper:active {
  background: #f5f5f5;
}

.action-icon {
  font-size: 40rpx;
  display: block;
  line-height: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
