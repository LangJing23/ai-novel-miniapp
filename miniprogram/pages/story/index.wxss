/* pages/story/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 30rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.select-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.select-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 12rpx;
}

.link-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e6f0ff 100%);
  color: #1677ff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid #d6e4ff;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.1);
}

.link-btn-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16rpx;
}

/* Tab切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-weight: 600;
}

.tab-content {
  margin-bottom: 30rpx;
}

/* 输入框 */
.input-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  text-align: left;
}

.char-count {
  position: absolute;
  bottom: 10rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 字数选择器 */
.length-selector {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.length-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.length-picker {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(79, 172, 254, 0.3);
  margin-bottom: 30rpx;
}

.generate-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #d0d0d0 0%, #b0b0b0 100%);
  box-shadow: none;
}

/* 大纲列表 */
.outline-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.outline-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.outline-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border-left: 4rpx solid #4facfe;
}

.outline-item.clickable {
  cursor: pointer;
}

.outline-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.outline-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.outline-item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.outline-edit {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
}

.outline-generate-btn {
  margin-left: 12rpx;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}

.outline-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-left: 64rpx;
}

/* 正文编辑区 */
.content-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.content-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn-mini {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  height: auto;
  line-height: 1.5;
}

.content-textarea {
  width: 100%;
  min-height: 400rpx;
  font-size: 28rpx;
  line-height: 2;
  color: #333;
  text-align: left;
}

/* 内联标题输入样式 */
.title-input-inline {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: none;
  box-sizing: border-box;
}

/* 保存操作区域 - 作为正文Tab的一部分 */
.save-action-box {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(79, 172, 254, 0.3);
}

.save-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #d0d0d0 0%, #b0b0b0 100%);
  box-shadow: none;
}

/* 已选择的角色标签 */
.selected-characters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.character-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
}

.tag-name {
  margin-right: 8rpx;
}

.tag-remove {
  font-size: 32rpx;
  line-height: 1;
  cursor: pointer;
  padding: 0 4rpx;
}

