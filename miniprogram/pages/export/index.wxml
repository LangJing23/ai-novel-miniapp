<!--pages/export/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">导出故事</text>
    <text class="subtitle">{{story ? story.title : '选择要导出的故事'}}</text>
  </view>

  <view wx:if="{{story}}" class="content">
    <!-- 导出格式选择 -->
    <view class="section">
      <text class="section-title">导出格式</text>
      <radio-group bindchange="onFormatChange">
        <label class="radio-item">
          <radio value="txt" checked="{{exportFormat === 'txt'}}" />
          <text>文本格式（.txt）</text>
        </label>
        <label class="radio-item">
          <radio value="image" checked="{{exportFormat === 'image'}}" />
          <text>图片格式（.png）</text>
        </label>
      </radio-group>
    </view>

    <!-- 导出选项 -->
    <view class="section" wx:if="{{exportFormat === 'txt'}}">
      <text class="section-title">导出选项</text>
      <label class="switch-item">
        <switch checked="{{includeImages}}" bindchange="onIncludeImagesChange" />
        <text>包含插画说明</text>
      </label>
    </view>

    <!-- 故事预览 -->
    <view class="section">
      <text class="section-title">故事预览</text>
      <view class="preview-box">
        <text class="preview-title">{{story.title || '未命名故事'}}</text>
        <text class="preview-summary">{{story.summary || story.premise || ''}}</text>
        <text class="preview-meta">
          字数：{{story.content ? story.content.length : 0}}字
          · 大纲节点：{{story.outline ? story.outline.length : 0}}个
          · 插画：{{story.images ? story.images.length : 0}}张
        </text>
      </view>
    </view>

    <!-- 导出按钮 -->
    <button class="export-btn" bindtap="exportStory">
      导出故事
    </button>
  </view>

  <view wx:else class="empty">
    <text>请从故事详情页进入导出页面</text>
  </view>
</view>






