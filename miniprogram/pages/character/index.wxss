/* pages/character/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.input-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  position: relative;
}

.input-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  text-align: left;
}

.char-count {
  position: absolute;
  bottom: 10rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.example-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.example-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.example-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #1677ff;
}

.example-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.generate-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #d0d0d0 0%, #b0b0b0 100%);
  box-shadow: none;
}

/* 结果页面样式 */
.result-section {
  padding-bottom: 40rpx;
}

.result-header {
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.character-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-section {
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-left: 20rpx;
  border-left: 6rpx solid #667eea;
  flex: 1;
}

.edit-icon {
  font-size: 32rpx;
  padding: 8rpx 16rpx;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 0.3s;
}

.edit-icon:active {
  opacity: 1;
}

.card-section.editable {
  position: relative;
  transition: background 0.3s;
}

.card-section.editable:active {
  background: #f8f9fa;
}

.card-section.editing {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: -20rpx;
  margin-bottom: 20rpx;
}

.section-content-wrapper {
  width: 100%;
  height: 300rpx;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  word-wrap: break-word;
  word-break: break-all;
  white-space: normal;
  width: 100%;
  box-sizing: border-box;
  padding: 0;
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.info-label {
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: #f0f4ff;
  color: #1677ff;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag.taboo {
  background: #fff0f0;
  color: #ff4d4f;
}

/* 编辑相关样式 */
.edit-container {
  margin-top: 20rpx;
}

.edit-textarea {
  width: 100%;
  height: 300rpx;
  padding: 20rpx;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  text-align: left !important;
  text-align-last: left;
  /* 固定高度，内容超出时可滚动（小程序 textarea 默认支持滚动） */
}

.edit-textarea::placeholder {
  text-align: left !important;
}

.edit-info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.edit-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
  padding-right: 16rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.edit-input {
  flex: 1;
  min-height: 64rpx;
  padding: 18rpx 20rpx;
  margin: 0;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  text-align: left !important;
  text-align-last: left;
  line-height: 1.5;
}

.edit-input::placeholder {
  text-align: left !important;
}

.edit-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.edit-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.edit-btn.cancel {
  color: #999;
  background: #f5f5f5;
}

.edit-btn.save {
  color: #fff;
  background: #667eea;
}

.action-btn.active {
  background: #667eea;
  color: #fff;
}

.action-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #666;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
}
