/* pages/dialog/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.page-header {
  margin-bottom: 40rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.select-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.select-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-text:empty::before {
  content: '请选择';
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 12rpx;
}

.link-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #f0f4ff 0%, #e6f0ff 100%);
  color: #1677ff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid #d6e4ff;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.1);
  transition: all 0.3s;
}

.link-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.link-btn-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 16rpx;
}

.input-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  text-align: left;
}

.char-count {
  position: absolute;
  bottom: 10rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.example-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.example-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.example-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #4facfe;
}

.example-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(79, 172, 254, 0.3);
}

.generate-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #d0d0d0 0%, #b0b0b0 100%);
  box-shadow: none;
}

.result-section {
  padding-bottom: 40rpx;
}

.result-header {
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.dialog-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.dialog-content {
  min-height: 200rpx;
}

.dialog-text {
  font-size: 30rpx;
  color: #333;
  line-height: 2;
  white-space: pre-wrap;
}

.action-buttons {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
  margin-left: -10rpx;
  margin-right: -10rpx;
}

.action-buttons .action-btn {
  flex: 1;
  min-width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx 10rpx;
}

.action-btn {
  height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #666;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
}
